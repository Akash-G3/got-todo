gotodo_PRIMARY.ENV="local"

gotodo_SERVER.PORT="8080"
gotodo_SERVER.READ_TIMEOUT="30"
gotodo_SERVER.WRITE_TIMEOUT="30"
gotodo_SERVER.IDLE_TIMEOUT="60"
gotodo_SERVER.CORS_ALLOWED_ORIGINS="http://localhost:3000"

gotodo_DATABASE.HOST="localhost"
gotodo_DATABASE.PORT="5432"
gotodo_DATABASE.USER="postgres"
gotodo_DATABASE.PASSWORD=""
gotodo_DATABASE.NAME="gotodo"
gotodo_DATABASE.SSL_MODE="disable"
gotodo_DATABASE.MAX_OPEN_CONNS="25"
gotodo_DATABASE.MAX_IDLE_CONNS="25"
gotodo_DATABASE.CONN_MAX_LIFETIME="300"
gotodo_DATABASE.CONN_MAX_IDLE_TIME="300"

gotodo_AUTH.SECRET_KEY="secret"

gotodo_INTEGRATION.RESEND_API_KEY="resend_key"

gotodo_REDIS.ADDRESS="redis://localhost:6379"

# ============================================================================
# OBSERVABILITY CONFIGURATION
# ============================================================================

# Service Identity
gotodo_OBSERVABILITY.SERVICE_NAME="gotodo"
gotodo_OBSERVABILITY.ENVIRONMENT="development"

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Basic Logging Settings
gotodo_OBSERVABILITY.LOGGING.LEVEL="debug"
gotodo_OBSERVABILITY.LOGGING.FORMAT="console"
gotodo_OBSERVABILITY.LOGGING.SLOW_QUERY_THRESHOLD="100ms"

# ============================================================================
# NEW RELIC CONFIGURATION
# ============================================================================

# New Relic APM
gotodo_OBSERVABILITY.NEW_RELIC.LICENSE_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
gotodo_OBSERVABILITY.NEW_RELIC.APP_LOG_FORWARDING_ENABLED="true"
gotodo_OBSERVABILITY.NEW_RELIC.DISTRIBUTED_TRACING_ENABLED="true"
gotodo_OBSERVABILITY.NEW_RELIC.DEBUG_LOGGING="false"

# ============================================================================
# HEALTH CHECKS CONFIGURATION
# ============================================================================

# Health Check Settings
gotodo_OBSERVABILITY.HEALTH_CHECKS.ENABLED="true"
gotodo_OBSERVABILITY.HEALTH_CHECKS.INTERVAL="30s"
gotodo_OBSERVABILITY.HEALTH_CHECKS.TIMEOUT="5s"
gotodo_OBSERVABILITY.HEALTH_CHECKS.CHECKS="database,redis"