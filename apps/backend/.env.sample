go-todo_PRIMARY.ENV="local"

go-todo_SERVER.PORT="8080"
go-todo_SERVER.READ_TIMEOUT="30"
go-todo_SERVER.WRITE_TIMEOUT="30"
go-todo_SERVER.IDLE_TIMEOUT="60"
go-todo_SERVER.CORS_ALLOWED_ORIGINS="http://localhost:3000"

go-todo_DATABASE.HOST="localhost"
go-todo_DATABASE.PORT="5432"
go-todo_DATABASE.USER="postgres"
go-todo_DATABASE.PASSWORD=""
go-todo_DATABASE.NAME="go-todo"
go-todo_DATABASE.SSL_MODE="disable"
go-todo_DATABASE.MAX_OPEN_CONNS="25"
go-todo_DATABASE.MAX_IDLE_CONNS="25"
go-todo_DATABASE.CONN_MAX_LIFETIME="300"
go-todo_DATABASE.CONN_MAX_IDLE_TIME="300"

go-todo_AUTH.SECRET_KEY="secret"

go-todo_INTEGRATION.RESEND_API_KEY="resend_key"

go-todo_REDIS.ADDRESS="redis://localhost:6379"

# ============================================================================
# OBSERVABILITY CONFIGURATION
# ============================================================================

# Service Identity
go-todo_OBSERVABILITY.SERVICE_NAME="go-todo"
go-todo_OBSERVABILITY.ENVIRONMENT="development"

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Basic Logging Settings
go-todo_OBSERVABILITY.LOGGING.LEVEL="debug"
go-todo_OBSERVABILITY.LOGGING.FORMAT="console"
go-todo_OBSERVABILITY.LOGGING.SLOW_QUERY_THRESHOLD="100ms"

# ============================================================================
# NEW RELIC CONFIGURATION
# ============================================================================

# New Relic APM
go-todo_OBSERVABILITY.NEW_RELIC.LICENSE_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
go-todo_OBSERVABILITY.NEW_RELIC.APP_LOG_FORWARDING_ENABLED="true"
go-todo_OBSERVABILITY.NEW_RELIC.DISTRIBUTED_TRACING_ENABLED="true"
go-todo_OBSERVABILITY.NEW_RELIC.DEBUG_LOGGING="false"

# ============================================================================
# HEALTH CHECKS CONFIGURATION
# ============================================================================

# Health Check Settings
go-todo_OBSERVABILITY.HEALTH_CHECKS.ENABLED="true"
go-todo_OBSERVABILITY.HEALTH_CHECKS.INTERVAL="30s"
go-todo_OBSERVABILITY.HEALTH_CHECKS.TIMEOUT="5s"
go-todo_OBSERVABILITY.HEALTH_CHECKS.CHECKS="database,redis"